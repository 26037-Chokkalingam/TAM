<Window x:Class="TAM.Dialogs.EditHistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit History" Height="500" Width="700"
        WindowStyle="ToolWindow" ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        MinHeight="350" MinWidth="500" FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#AD1457" Padding="20,16">
            <StackPanel>
                <TextBlock x:Name="TitleText" Text="Edit History" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Text="Previous versions of this record" FontSize="12" Foreground="#F8BBD0" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <DataGrid x:Name="HistoryGrid" Grid.Row="1" AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  SelectionMode="Single" Margin="16">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Changed At" Binding="{Binding ChangedAt, StringFormat='dd-MM-yyyy HH:mm:ss'}" Width="160"/>
                <DataGridTextColumn Header="Change Description" Binding="{Binding ChangeDescription}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="16,12">
            <Button Content="Close" IsCancel="True" Style="{StaticResource SecondaryButton}"
                    Width="90" HorizontalAlignment="Right"/>
        </Border>
    </Grid>
</Window>
