<Window x:Class="TAM.Dialogs.AccessoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:TAM.Helpers"
        Title="Accessory" Height="500" Width="500"
        WindowStyle="ToolWindow" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#AD1457" Padding="20,16">
            <StackPanel>
                <TextBlock x:Name="TitleText" Text="Add Accessory" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Text="Enter accessory details below" FontSize="12" Foreground="#F8BBD0" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16">
            <StackPanel>
                <TextBlock Text="Name * (must be unique)" Style="{StaticResource SectionLabel}"/>
                <TextBox x:Name="NameBox" Style="{StaticResource FormTextBox}" Margin="0,0,0,14"/>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Category" Style="{StaticResource SectionLabel}"/>
                        <ComboBox x:Name="CategoryBox" Style="{StaticResource FormComboBox}"
                                  IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True"
                                  TextBoxBase.TextChanged="CategoryFilter_TextChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Unit" Style="{StaticResource SectionLabel}"/>
                        <ComboBox x:Name="UnitBox" Style="{StaticResource FormComboBox}" IsEditable="True">
                            <ComboBoxItem Content="pcs"/>
                            <ComboBoxItem Content="meters"/>
                            <ComboBoxItem Content="kg"/>
                            <ComboBoxItem Content="grams"/>
                            <ComboBoxItem Content="rolls"/>
                            <ComboBoxItem Content="boxes"/>
                            <ComboBoxItem Content="pairs"/>
                            <ComboBoxItem Content="sets"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Current Stock" Style="{StaticResource SectionLabel}"/>
                        <TextBox x:Name="StockBox" Style="{StaticResource FormTextBox}" Text="0"
                                 h:NumericInput.IsDecimal="True"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Minimum Stock (alert)" Style="{StaticResource SectionLabel}"/>
                        <TextBox x:Name="MinStockBox" Style="{StaticResource FormTextBox}" Text="0"
                                 h:NumericInput.IsDecimal="True"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Description" Style="{StaticResource SectionLabel}"/>
                <TextBox x:Name="DescBox" Style="{StaticResource FormTextBox}" Height="60"
                         AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,14"/>

                <CheckBox x:Name="ActiveCheck" Content="Active" IsChecked="True" FontSize="13" Margin="0,4,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="24,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" IsCancel="True" Style="{StaticResource SecondaryButton}" Width="90" Margin="0,0,10,0"/>
                <Button x:Name="SaveBtn" Content="Save" Style="{StaticResource PrimaryButton}" Width="90" Click="SaveBtn_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
