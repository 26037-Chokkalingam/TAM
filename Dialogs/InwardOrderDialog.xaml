<Window x:Class="TAM.Dialogs.InwardOrderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:TAM.Helpers"
        Title="Inward Order" Height="640" Width="780"
        WindowStyle="ToolWindow" ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        MinHeight="500" MinWidth="650" FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#AD1457" Padding="20,16">
            <StackPanel>
                <TextBlock x:Name="TitleText" Text="Create Inward Order" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock x:Name="SubTitleText" Text="Record goods received" FontSize="12" Foreground="#F8BBD0" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16">
            <StackPanel>
                <!-- PO Reference (read-only, shown when from PO) -->
                <Border x:Name="PORefPanel" Background="#FCE4EC" CornerRadius="6" Padding="12" Margin="0,0,0,14"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Converting Purchase Order" FontWeight="SemiBold" FontSize="13" Foreground="#AD1457"/>
                        <TextBlock x:Name="PORefText" FontSize="12" Foreground="#C2185B" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Vendor *" Style="{StaticResource SectionLabel}"/>
                        <ComboBox x:Name="VendorCombo" Style="{StaticResource FormComboBox}"
                                  DisplayMemberPath="Name" SelectedValuePath="VendorId"
                                  IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True"
                                  TextBoxBase.TextChanged="VendorFilter_TextChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Bill No. *" Style="{StaticResource SectionLabel}"/>
                        <TextBox x:Name="BillNoBox" Style="{StaticResource FormTextBox}"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Inward Date" Style="{StaticResource SectionLabel}"/>
                        <DatePicker x:Name="InwardDatePicker" FontFamily="Segoe UI" FontSize="13"
                                    BorderBrush="#E0E0E0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" x:Name="PartialPanel">
                        <TextBlock Text="Inward Mode" Style="{StaticResource SectionLabel}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <RadioButton x:Name="FullRadio" Content="Full Inward" IsChecked="True"
                                         FontSize="13" Margin="0,0,16,0"/>
                            <RadioButton x:Name="PartialRadio" Content="Partial Inward" FontSize="13"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Notes" Style="{StaticResource SectionLabel}"/>
                <TextBox x:Name="NotesBox" Style="{StaticResource FormTextBox}" Height="45"
                         AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,16"/>

                <!-- Items section -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Items" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button x:Name="AddItemBtn" Grid.Column="1" Content="+ Add Item" Click="AddItem_Click"
                            Style="{StaticResource SecondaryButton}" Padding="12,6"/>
                </Grid>

                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4">
                    <DataGrid x:Name="ItemsGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                              CanUserDeleteRows="False" SelectionMode="Single" MinHeight="150"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F5F5F5">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Accessory *" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding AccessoryName}" Margin="8,4"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.Accessories, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  DisplayMemberPath="Name" SelectedValuePath="AccessoryId"
                                                  SelectedValue="{Binding AccessoryId, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectionChanged="AccessoryCombo_Changed"
                                                  IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True"
                                                  TextBoxBase.TextChanged="AccessoryFilter_TextChanged"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Requested" Binding="{Binding RequestedQty}" Width="90" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Qty *" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="90">
                                <DataGridTextColumn.EditingElementStyle>
                                    <Style TargetType="TextBox">
                                        <Setter Property="h:NumericInput.IsDecimal" Value="True"/>
                                    </Style>
                                </DataGridTextColumn.EditingElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="X" Click="RemoveItem_Click" Tag="{Binding}"
                                                Background="#FFEBEE" Foreground="#E53935" BorderThickness="0"
                                                Padding="8,4" Cursor="Hand"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="24,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" IsCancel="True" Style="{StaticResource SecondaryButton}" Width="90" Margin="0,0,10,0"/>
                <Button x:Name="SaveBtn" Content="Save" Style="{StaticResource PrimaryButton}" Width="100" Click="SaveBtn_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
