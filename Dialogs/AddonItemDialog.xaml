<Window x:Class="TAM.Dialogs.AddonItemDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Item" Height="260" Width="460"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        FontFamily="Segoe UI" Background="Transparent">
    <Border Background="White" CornerRadius="10" BorderBrush="#E0E0E0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#30000000" BlurRadius="20" ShadowDepth="4" Direction="270"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#AD1457" CornerRadius="10,10,0,0" Padding="24,16">
                <Grid>
                    <TextBlock x:Name="TitleText" Text="Add Item" FontSize="16" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Width="28" Height="28" IsCancel="True"
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Foreground="White"
                            FontSize="16" FontWeight="Bold" Content="×"
                            ToolTip="Cancel">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent" CornerRadius="4" Width="28" Height="28">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#880E4F"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Body -->
            <StackPanel Grid.Row="1" Margin="24,24,24,16" VerticalAlignment="Top">
                <TextBlock x:Name="LabelText" Text="Name" Style="{StaticResource SectionLabel}" Margin="0,0,0,6"/>
                <TextBox x:Name="NameBox" Style="{StaticResource FormTextBox}" MinHeight="38"
                         VerticalContentAlignment="Center"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         TextWrapping="Wrap"
                         KeyDown="NameBox_KeyDown"/>
                <TextBlock x:Name="ErrorText" Text="" Foreground="#E53935" FontSize="11"
                           Margin="0,6,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2" BorderBrush="#F0F0F0" BorderThickness="0,1,0,0" Padding="24,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" IsCancel="True" Style="{StaticResource SecondaryButton}"
                            Width="90" Height="36" Margin="0,0,10,0"/>
                    <Button Content="Save" Style="{StaticResource PrimaryButton}"
                            Width="90" Height="36" Click="SaveBtn_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
