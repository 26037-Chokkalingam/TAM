<Window x:Class="TAM.Dialogs.AddonItemDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Item" Height="200" Width="400"
        WindowStyle="ToolWindow" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#AD1457" Padding="20,14">
            <TextBlock x:Name="TitleText" Text="Add Item" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
        </Border>

        <StackPanel Grid.Row="1" Margin="24,18,24,8">
            <TextBlock x:Name="LabelText" Text="Name" Style="{StaticResource SectionLabel}"/>
            <TextBox x:Name="NameBox" Style="{StaticResource FormTextBox}"
                     KeyDown="NameBox_KeyDown"/>
        </StackPanel>

        <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="24,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" IsCancel="True" Style="{StaticResource SecondaryButton}" Width="80" Margin="0,0,10,0"/>
                <Button Content="Save" Style="{StaticResource PrimaryButton}" Width="80" Click="SaveBtn_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
