<Window x:Class="TAM.Dialogs.ReturnOrderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Return Order" Height="580" Width="700"
        WindowStyle="ToolWindow" ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        MinHeight="450" MinWidth="600" FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#AD1457" Padding="20,16">
            <StackPanel>
                <TextBlock x:Name="TitleText" Text="Process Return" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock x:Name="SubTitleText" Text="Enter return quantities for each item" FontSize="12" Foreground="#F8BBD0" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16">
            <StackPanel>
                <!-- Reference info -->
                <Border Background="#FCE4EC" CornerRadius="6" Padding="12" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Outward Order" Style="{StaticResource SectionLabel}"/>
                            <TextBlock x:Name="OutwardNoText" FontWeight="SemiBold" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Recipient" Style="{StaticResource SectionLabel}"/>
                            <TextBlock x:Name="RecipientText" FontSize="13"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" x:Name="ReturnTypePanel">
                        <TextBlock Text="Return Type" Style="{StaticResource SectionLabel}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <RadioButton x:Name="FullReturnRadio" Content="Full Return" IsChecked="True"
                                         FontSize="13" Margin="0,0,16,0" Checked="ReturnType_Changed"/>
                            <RadioButton x:Name="PartialReturnRadio" Content="Partial Return"
                                         FontSize="13" Checked="ReturnType_Changed"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Return Date" Style="{StaticResource SectionLabel}"/>
                        <DatePicker x:Name="ReturnDatePicker" FontFamily="Segoe UI" FontSize="13" BorderBrush="#E0E0E0"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Notes" Style="{StaticResource SectionLabel}"/>
                <TextBox x:Name="NotesBox" Style="{StaticResource FormTextBox}" Height="45"
                         AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,16"/>

                <!-- Items -->
                <TextBlock Text="Return Items" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4">
                    <DataGrid x:Name="ItemsGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                              CanUserDeleteRows="False" SelectionMode="Single" MinHeight="150"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F5F5F5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Accessory" Binding="{Binding AccessoryName}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Dispatched" Binding="{Binding OriginalQty}" Width="90" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Already Returned" Binding="{Binding AlreadyReturned}" Width="120" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Max Returnable" Binding="{Binding MaxReturnable}" Width="110" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Return Qty" Binding="{Binding ReturnQty, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="24,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" IsCancel="True" Style="{StaticResource SecondaryButton}" Width="90" Margin="0,0,10,0"/>
                <Button x:Name="SaveBtn" Content="Confirm Return" Style="{StaticResource PrimaryButton}" Width="130" Click="SaveBtn_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
