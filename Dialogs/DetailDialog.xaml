<Window x:Class="TAM.Dialogs.DetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Details" Height="620" Width="720"
        WindowStyle="ToolWindow" ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        MinHeight="450" MinWidth="550" FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Pink Header -->
        <Border Grid.Row="0" Background="#AD1457" Padding="20,14">
            <StackPanel>
                <TextBlock x:Name="TitleText" FontSize="17" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock x:Name="SubtitleText" FontSize="12" Foreground="#F8BBD0" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16,24,8">
            <StackPanel>
                <!-- Info fields -->
                <Border Background="#FFF0F5" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <ItemsControl x:Name="FieldsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="12"
                                               Foreground="#757575" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="13"
                                               Foreground="#212121" TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Items grid (shown only when items exist) -->
                <StackPanel x:Name="ItemsPanel">
                    <TextBlock x:Name="ItemsHeaderText" FontSize="14" FontWeight="SemiBold"
                               Foreground="#AD1457" Margin="0,0,0,8"/>
                    <DataGrid x:Name="ItemsGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                              CanUserDeleteRows="False" IsReadOnly="True" MaxHeight="200"
                              SelectionMode="Single" BorderBrush="#E0E0E0" BorderThickness="1"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F5F5F5"
                              RowBackground="White" AlternatingRowBackground="#FAFAFA"
                              FontFamily="Segoe UI" FontSize="13">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#FFF0F5"/>
                                <Setter Property="Foreground" Value="#AD1457"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="8,5"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                    </DataGrid>
                </StackPanel>

                <!-- Edit History -->
                <Expander Header="Edit History" Margin="0,16,0,0" IsExpanded="False">
                    <Expander.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" FontWeight="SemiBold" Foreground="#AD1457"/>
                        </DataTemplate>
                    </Expander.HeaderTemplate>
                    <DataGrid x:Name="HistoryGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                              IsReadOnly="True" MaxHeight="200" BorderBrush="#E0E0E0" BorderThickness="1"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F5F5F5"
                              RowBackground="White" AlternatingRowBackground="#FAFAFA"
                              FontFamily="Segoe UI" FontSize="12" Margin="0,8,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Changed At" Binding="{Binding ChangedAt, StringFormat='dd-MM-yyyy HH:mm'}" Width="140"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding ChangeDescription}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Expander>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="24,12">
            <Button Content="Close" IsCancel="True" Style="{StaticResource SecondaryButton}"
                    Width="90" HorizontalAlignment="Right"/>
        </Border>
    </Grid>
</Window>
