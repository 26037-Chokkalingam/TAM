<Window x:Class="TAM.Dialogs.VendorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vendor" Height="480" Width="500"
        WindowStyle="ToolWindow" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#AD1457" Padding="20,16">
            <StackPanel>
                <TextBlock x:Name="TitleText" Text="Add Vendor" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Text="Enter vendor details below" FontSize="12" Foreground="#F8BBD0" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16">
            <StackPanel>
                <TextBlock Text="Name *" Style="{StaticResource SectionLabel}"/>
                <TextBox x:Name="NameBox" Style="{StaticResource FormTextBox}" Margin="0,0,0,14"/>

                <TextBlock Text="Contact Person" Style="{StaticResource SectionLabel}"/>
                <TextBox x:Name="ContactBox" Style="{StaticResource FormTextBox}" Margin="0,0,0,14"/>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Phone" Style="{StaticResource SectionLabel}"/>
                        <TextBox x:Name="PhoneBox" Style="{StaticResource FormTextBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Email" Style="{StaticResource SectionLabel}"/>
                        <TextBox x:Name="EmailBox" Style="{StaticResource FormTextBox}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Address" Style="{StaticResource SectionLabel}"/>
                <TextBox x:Name="AddressBox" Style="{StaticResource FormTextBox}" Height="60"
                         AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,14"/>

                <CheckBox x:Name="ActiveCheck" Content="Active" IsChecked="True" Margin="0,4,0,0"
                          FontSize="13"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="24,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" IsCancel="True" Style="{StaticResource SecondaryButton}"
                        Width="90" Margin="0,0,10,0"/>
                <Button x:Name="SaveBtn" Content="Save" Style="{StaticResource PrimaryButton}"
                        Width="90" Click="SaveBtn_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
