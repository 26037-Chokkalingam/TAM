<UserControl x:Class="TAM.Views.BackupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Backup &amp; Restore" Style="{StaticResource PageTitle}" Margin="0,0,0,24"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Status Message -->
                <Border Background="#E8F5E9" CornerRadius="8" Padding="16" Margin="0,0,0,20"
                        Visibility="{Binding StatusMessage, Converter={StaticResource NullToVis}}">
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13" Foreground="#2E7D32"/>
                </Border>

                <!-- Backup Section -->
                <Border Background="White" CornerRadius="8" Padding="24" Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#10000000" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Data Backup" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="Export all your data as a JSON backup file. Store it in a safe location." FontSize="13"
                                   Foreground="{StaticResource TextSecondary}" Margin="0,0,0,16"/>
                        <Button Content="Export Backup (.json)" Command="{Binding ExportCommand}"
                                Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Padding="20,10"/>
                    </StackPanel>
                </Border>

                <!-- Restore Section -->
                <Border Background="White" CornerRadius="8" Padding="24" Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#10000000" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Data Restore / Import" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="Import data from a previously exported backup. You can choose to append or replace existing data."
                                   FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,16"/>
                        <Button Content="Import Backup (.json)" Command="{Binding ImportCommand}"
                                Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" Padding="20,10"/>
                    </StackPanel>
                </Border>

                <!-- Reports Section -->
                <Border Background="White" CornerRadius="8" Padding="24" Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#10000000" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Export Reports" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="Download detailed reports as Excel files." FontSize="13"
                                   Foreground="{StaticResource TextSecondary}" Margin="0,0,0,16"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Inward Report (Excel)" Command="{Binding ExportInwardExcelCommand}"
                                    Style="{StaticResource SecondaryButton}" Padding="16,10" Margin="0,0,12,0"/>
                            <Button Content="Outward Report (Excel)" Command="{Binding ExportOutwardExcelCommand}"
                                    Style="{StaticResource SecondaryButton}" Padding="16,10" Margin="0,0,12,0"/>
                            <Button Content="PO Report (Excel)" Command="{Binding ExportPOExcelCommand}"
                                    Style="{StaticResource SecondaryButton}" Padding="16,10"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
