<UserControl x:Class="TAM.Views.ManageAddonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Manage Add-Ons" Style="{StaticResource PageTitle}"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- CATEGORIES -->
            <Border Grid.Column="0" Background="White" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect Color="#10000000" BlurRadius="4" ShadowDepth="1"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FCE4EC" CornerRadius="8,8,0,0" Padding="18,14">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Categories" FontSize="15" FontWeight="SemiBold" Foreground="#AD1457"/>
                            <TextBlock Text=" — accessory groupings" FontSize="12" Foreground="#C2185B" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Padding="14,10" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                        <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBox Text="{Binding CategorySearch, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormTextBox}" Width="180"
                                     Tag="Search categories…"/>
                            <Button Content="+ Add" Command="{Binding AddCategoryCommand}"
                                    Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Padding="12,6"/>
                            <Button Content="Edit" Command="{Binding EditCategoryCommand}"
                                    Style="{StaticResource SecondaryButton}" Margin="6,0,0,0" Padding="12,6"/>
                            <Button Content="Delete" Command="{Binding DeleteCategoryCommand}"
                                    Style="{StaticResource DangerButton}" Margin="6,0,0,0" Padding="12,6"/>
                        </WrapPanel>
                    </Border>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}"
                              Style="{StaticResource AppDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Category Name" Binding="{Binding Name}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- STYLES -->
            <Border Grid.Column="2" Background="White" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect Color="#10000000" BlurRadius="4" ShadowDepth="1"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FCE4EC" CornerRadius="8,8,0,0" Padding="18,14">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Styles" FontSize="15" FontWeight="SemiBold" Foreground="#AD1457"/>
                            <TextBlock Text=" — used in outward orders" FontSize="12" Foreground="#C2185B" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Padding="14,10" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                        <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBox Text="{Binding StyleSearch, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormTextBox}" Width="180"
                                     Tag="Search styles…"/>
                            <Button Content="+ Add" Command="{Binding AddStyleCommand}"
                                    Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Padding="12,6"/>
                            <Button Content="Edit" Command="{Binding EditStyleCommand}"
                                    Style="{StaticResource SecondaryButton}" Margin="6,0,0,0" Padding="12,6"/>
                            <Button Content="Delete" Command="{Binding DeleteStyleCommand}"
                                    Style="{StaticResource DangerButton}" Margin="6,0,0,0" Padding="12,6"/>
                        </WrapPanel>
                    </Border>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding Styles}" SelectedItem="{Binding SelectedStyle}"
                              Style="{StaticResource AppDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Style Name" Binding="{Binding Name}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
