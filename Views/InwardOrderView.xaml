<UserControl x:Class="TAM.Views.InwardOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Inward Orders" Style="{StaticResource PageTitle}"/>
            <Button Grid.Column="1" Content="+ Direct Inward" Command="{Binding AddDirectCommand}"
                    Style="{StaticResource PrimaryButton}" VerticalAlignment="Center"/>
        </Grid>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="14,10" Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect Color="#10000000" BlurRadius="4" ShadowDepth="1"/>
            </Border.Effect>
            <WrapPanel Orientation="Horizontal">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FormTextBox}" Width="220"
                         Tag="Search inward orders…" VerticalAlignment="Center"/>
                <TextBlock Text="From:" VerticalAlignment="Center" Margin="12,0,6,0" Foreground="{StaticResource TextSecondary}"/>
                <DatePicker SelectedDate="{Binding FilterDateFrom, UpdateSourceTrigger=PropertyChanged}"
                            Width="120" FontFamily="Segoe UI" FontSize="13" VerticalAlignment="Center"/>
                <TextBlock Text="To:" VerticalAlignment="Center" Margin="8,0,6,0" Foreground="{StaticResource TextSecondary}"/>
                <DatePicker SelectedDate="{Binding FilterDateTo, UpdateSourceTrigger=PropertyChanged}"
                            Width="120" FontFamily="Segoe UI" FontSize="13" VerticalAlignment="Center"/>
                <Button Content="Edit" Command="{Binding EditCommand}" Style="{StaticResource SecondaryButton}" Margin="12,0,0,0"/>
                <Button Content="Edit History" Command="{Binding ViewHistoryCommand}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/>
                <Button Content="Clear" Command="{Binding ClearFilterCommand}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/>
                <Button Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/>
            </WrapPanel>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect Color="#10000000" BlurRadius="4" ShadowDepth="1"/>
            </Border.Effect>
            <DataGrid ItemsSource="{Binding Orders}" SelectedItem="{Binding Selected}"
                      Style="{StaticResource AppDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Inward No." Binding="{Binding InwardNumber}" Width="130"/>
                    <DataGridTextColumn Header="Bill No." Binding="{Binding BillNo}" Width="110"/>
                    <DataGridTextColumn Header="Vendor" Width="130">
                        <DataGridTextColumn.Binding>
                            <Binding Path="VendorId" Converter="{StaticResource VendorName}"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="PO Reference" Width="110">
                        <DataGridTextColumn.Binding>
                            <Binding Path="POId" Converter="{StaticResource POIdToRef}"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Items" Binding="{Binding Items.Count}" Width="60"/>
                    <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding InwardDate, StringFormat='dd-MM-yyyy'}" Width="100"/>
                    <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt, StringFormat='dd-MM-yyyy'}" Width="100"/>
                    <DataGridTemplateColumn Header="" Width="46">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Tag="{Binding}" Click="ViewDetail_Click" ToolTip="View Details"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4">
                                    <Path Data="M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5ZM12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17ZM12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9Z"
                                          Fill="#AD1457" Stretch="Uniform" Width="16" Height="16"/>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
