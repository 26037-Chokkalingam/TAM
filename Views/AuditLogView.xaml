<UserControl x:Class="TAM.Views.AuditLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Audit Log" Style="{StaticResource PageTitle}" Margin="0,0,0,16"/>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="12" Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect Color="#10000000" BlurRadius="4" ShadowDepth="1"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Show last:" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,0"/>
                <TextBox Text="{Binding FetchCount, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FormTextBox}" Width="80"/>
                <TextBlock Text="events" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{StaticResource TextSecondary}"/>
                <Button Content="Load" Command="{Binding LoadCommand}" Style="{StaticResource PrimaryButton}" Margin="12,0,0,0"/>
                <Button Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/>
                <TextBlock VerticalAlignment="Center" Margin="20,0,0,0" Foreground="{StaticResource TextSecondary}">
                    <Run Text="Total events: "/>
                    <Run Text="{Binding TotalCount}"/>
                    <Run Text=" / 5000 max"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect Color="#10000000" BlurRadius="4" ShadowDepth="1"/>
            </Border.Effect>
            <DataGrid ItemsSource="{Binding Entries}" Style="{StaticResource AppDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp, StringFormat='dd-MM-yyyy HH:mm:ss'}" Width="160"/>
                    <DataGridTemplateColumn Header="Action" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#E3F2FD"/>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Action}" FontSize="11" FontWeight="SemiBold" Foreground="#1565C0"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Module" Binding="{Binding Module}" Width="130"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                    <DataGridTextColumn Header="Entity ID" Binding="{Binding EntityId}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
