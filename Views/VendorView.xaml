<UserControl x:Class="TAM.Views.VendorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Vendors" Style="{StaticResource PageTitle}"/>
            <Button Grid.Column="1" Content="+ Add Vendor" Command="{Binding AddCommand}"
                    Style="{StaticResource PrimaryButton}" VerticalAlignment="Center"/>
        </Grid>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="14,10" Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect Color="#10000000" BlurRadius="4" ShadowDepth="1"/>
            </Border.Effect>
            <WrapPanel Orientation="Horizontal">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FormTextBox}" Width="260"
                         Tag="Search vendors…" VerticalAlignment="Center"/>
                <Button Content="Edit" Command="{Binding EditCommand}" Style="{StaticResource SecondaryButton}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                <Button Content="Delete" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                <Button Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" VerticalAlignment="Center"/>
            </WrapPanel>
        </Border>

        <!-- Grid -->
        <Border Grid.Row="2" Background="White" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect Color="#10000000" BlurRadius="4" ShadowDepth="1"/>
            </Border.Effect>
            <DataGrid ItemsSource="{Binding Vendors}" SelectedItem="{Binding Selected}"
                      Style="{StaticResource AppDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Code" Binding="{Binding VendorCode}" Width="90"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Contact Person" Binding="{Binding ContactPerson}" Width="140"/>
                    <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="120"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180"/>
                    <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="180"/>
                    <DataGridTemplateColumn Header="Status" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#E8F5E9"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                    <Setter Property="Background" Value="#FFEBEE"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Active"/>
                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter Property="Text" Value="Inactive"/>
                                                        <Setter Property="Foreground" Value="#C62828"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt, StringFormat='dd-MM-yyyy'}" Width="90"/>
                    <DataGridTemplateColumn Header="" Width="46">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Tag="{Binding}" Click="ViewDetail_Click" ToolTip="View Details"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4">
                                    <Path Data="M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5ZM12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17ZM12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9Z"
                                          Fill="#AD1457" Stretch="Uniform" Width="16" Height="16"/>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
