<UserControl x:Class="TAM.Views.VendorSummaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Vendor Summary" Style="{StaticResource PageTitle}"/>
            <Button Grid.Column="1" Content="Refresh" Command="{Binding RefreshCommand}"
                    Style="{StaticResource SecondaryButton}" VerticalAlignment="Center"/>
        </Grid>

        <!-- Vendor Selector -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="14,12" Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect Color="#10000000" BlurRadius="4" ShadowDepth="1"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Select Vendor:" FontSize="13" FontWeight="SemiBold" Foreground="#757575"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <ComboBox ItemsSource="{Binding AllVendors}"
                          SelectedItem="{Binding SelectedVendor}"
                          DisplayMemberPath="Name"
                          Style="{StaticResource FormComboBox}"
                          Width="280" IsEditable="False"/>
                <TextBlock Text="Choose a vendor to see accessory-level breakdown"
                           FontSize="12" Foreground="#9E9E9E" VerticalAlignment="Center" Margin="16,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="2" Background="White" CornerRadius="8"
                Visibility="{Binding SelectedVendor, Converter={StaticResource InvNullToVis}}">
            <Border.Effect>
                <DropShadowEffect Color="#10000000" BlurRadius="4" ShadowDepth="1"/>
            </Border.Effect>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="No vendor selected" FontSize="16" FontWeight="SemiBold"
                           Foreground="#BDBDBD" HorizontalAlignment="Center"/>
                <TextBlock Text="Select a vendor above to view their accessory summary"
                           FontSize="13" Foreground="#BDBDBD" Margin="0,8,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Summary Table -->
        <Border Grid.Row="2" Background="White" CornerRadius="8"
                Visibility="{Binding SelectedVendor, Converter={StaticResource NullToVis}}">
            <Border.Effect>
                <DropShadowEffect Color="#10000000" BlurRadius="4" ShadowDepth="1"/>
            </Border.Effect>
            <DataGrid ItemsSource="{Binding Rows}" Style="{StaticResource AppDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Code" Binding="{Binding AccessoryCode}" Width="90"/>
                    <DataGridTextColumn Header="Accessory" Binding="{Binding AccessoryName}" Width="*"/>
                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="60"/>
                    <DataGridTextColumn Header="Bought" Binding="{Binding TotalBought}" Width="80"/>
                    <DataGridTextColumn Header="Sent Out" Binding="{Binding TotalSent}" Width="80"/>
                    <DataGridTextColumn Header="Returned" Binding="{Binding TotalReturned}" Width="85"/>
                    <DataGridTextColumn Header="Used" Binding="{Binding TotalUsed}" Width="70"/>
                    <DataGridTemplateColumn Header="In Hand" Width="85">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding InHand}" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#2E7D32"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding InHand}" Value="0">
                                                    <Setter Property="Foreground" Value="#9E9E9E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
