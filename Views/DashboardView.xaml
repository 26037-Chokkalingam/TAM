<UserControl x:Class="TAM.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- Clickable tile button style -->
        <Style x:Key="TileButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="20,16">
                            <Border.Effect>
                                <DropShadowEffect Color="#20000000" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFF0F5"/>
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#40AD1457" BlurRadius="12" ShadowDepth="3" Direction="270"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,24">
            <TextBlock Text="Dashboard" Style="{StaticResource PageTitle}" Margin="0,0,0,6"/>
            <TextBlock Text="Click any tile to navigate" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,20"/>

            <!-- Stats Row 1 -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/><ColumnDefinition Width="12"/>
                    <ColumnDefinition/><ColumnDefinition Width="12"/>
                    <ColumnDefinition/><ColumnDefinition Width="12"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Style="{StaticResource TileButton}" Command="{Binding NavVendorsCommand}">
                    <StackPanel>
                        <TextBlock Text="VENDORS" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding TotalVendors}" FontSize="36" FontWeight="Bold" Foreground="#AD1457"/>
                        <TextBlock Text="Active Vendors" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="2" Style="{StaticResource TileButton}" Command="{Binding NavAccessoriesCommand}">
                    <StackPanel>
                        <TextBlock Text="ACCESSORIES" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding TotalAccessories}" FontSize="36" FontWeight="Bold" Foreground="#1976D2"/>
                        <TextBlock Text="View Stock Summary" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="4" Style="{StaticResource TileButton}" Command="{Binding NavPendingPOCommand}">
                    <StackPanel>
                        <TextBlock Text="PURCHASE ORDERS" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding TotalPOs}" FontSize="36" FontWeight="Bold" Foreground="#388E3C"/>
                        <TextBlock FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0">
                            <Run Text="{Binding PendingPOs}"/>
                            <Run Text=" pending"/>
                        </TextBlock>
                    </StackPanel>
                </Button>

                <Button Grid.Column="6" Style="{StaticResource TileButton}" Command="{Binding NavLowStockCommand}">
                    <StackPanel>
                        <TextBlock Text="LOW STOCK" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding LowStock}" FontSize="36" FontWeight="Bold" Foreground="#E53935"/>
                        <TextBlock Text="View low stock items" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Stats Row 2 -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/><ColumnDefinition Width="12"/>
                    <ColumnDefinition/><ColumnDefinition Width="12"/>
                    <ColumnDefinition/><ColumnDefinition Width="12"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Style="{StaticResource TileButton}" Command="{Binding NavInwardCommand}">
                    <StackPanel>
                        <TextBlock Text="INWARD ORDERS" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding TotalInward}" FontSize="36" FontWeight="Bold" Foreground="#00796B"/>
                        <TextBlock Text="Total Received" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="2" Style="{StaticResource TileButton}" Command="{Binding NavOutwardCommand}">
                    <StackPanel>
                        <TextBlock Text="OUTWARD ORDERS" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding TotalOutward}" FontSize="36" FontWeight="Bold" Foreground="#F57C00"/>
                        <TextBlock Text="Total Dispatched" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="4" Style="{StaticResource TileButton}" Command="{Binding NavReturnCommand}">
                    <StackPanel>
                        <TextBlock Text="RETURN ORDERS" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="{Binding TotalReturns}" FontSize="36" FontWeight="Bold" Foreground="#7B1FA2"/>
                        <TextBlock Text="Total Returns" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Recent Activity -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect Color="#20000000" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Recent Inward Orders" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,12"/>
                        <ItemsControl ItemsSource="{Binding RecentInwards}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#F5F5F5" BorderThickness="0,0,0,1" Padding="0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding InwardNumber}" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Text="{Binding BillNo, StringFormat='Bill: {0}'}"
                                                           FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding InwardDate, StringFormat='dd-MM-yyyy'}"
                                                       FontSize="11" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="No recent inward orders" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                   HorizontalAlignment="Center" Margin="0,12,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RecentInwards.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect Color="#20000000" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Recent Outward Orders" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,12"/>
                        <ItemsControl ItemsSource="{Binding RecentOutwards}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#F5F5F5" BorderThickness="0,0,0,1" Padding="0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding OutwardNumber}" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Text="{Binding Recipient, StringFormat='To: {0}'}"
                                                           FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding OutwardDate, StringFormat='dd-MM-yyyy'}"
                                                       FontSize="11" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="No recent outward orders" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                   HorizontalAlignment="Center" Margin="0,12,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RecentOutwards.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
